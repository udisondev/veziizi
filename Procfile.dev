backend: air -c .air-backend.toml
frontend: cd frontend && npm run dev
members: go run ./backend/cmd/workers/members
invitations: go run ./backend/cmd/workers/invitations
pending-orgs: go run ./backend/cmd/workers/pending-organizations
organizations: go run ./backend/cmd/workers/organizations
freight-reqs: go run ./backend/cmd/workers/freight-requests
orders: go run ./backend/cmd/workers/orders
order-creator: go run ./backend/cmd/workers/order-creator
review-receiver: go run ./backend/cmd/workers/review-receiver
review-analyzer: go run ./backend/cmd/workers/review-analyzer
reviews-proj: go run ./backend/cmd/workers/reviews-projection
review-activator: go run ./backend/cmd/workers/review-activator
fraudster: go run ./backend/cmd/workers/fraudster-handler
order-fraud: go run ./backend/cmd/workers/order-fraud-analyzer
notif-dispatch: go run ./backend/cmd/workers/notification-dispatcher
telegram-sender: go run ./backend/cmd/workers/telegram-sender
support: go run ./backend/cmd/workers/support-tickets
rate-limiter: go run ./backend/cmd/workers/rate-limiter-cleanup
