# Database
POSTGRES_USER=veziizi
POSTGRES_PASSWORD=veziizi
POSTGRES_DB=veziizi
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# SEC-013: В production ОБЯЗАТЕЛЬНО используйте sslmode=require или sslmode=verify-full
# Пример для production: postgres://user:pass@host:5432/db?sslmode=require
DATABASE_URL=postgres://veziizi:veziizi@localhost:5432/veziizi?sslmode=disable

# HTTP Server
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

# Session
SESSION_SECRET=change-me-to-random-32-bytes-key
SESSION_ADMIN_SECRET=change-me-to-different-32-bytes-key
SESSION_NAME=veziizi_session
SESSION_ADMIN_NAME=veziizi_admin_session
SESSION_MAX_AGE=86400

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=veziizi_bot

# Email (Resend or SMTP)
EMAIL_ENABLED=false
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=noreply@veziizi.ru
EMAIL_FROM_NAME=Veziizi
# Resend API key (get from https://resend.com/api-keys)
RESEND_API_KEY=
# SMTP settings (alternative to Resend)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# Storage (future S3)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=

# Application
APP_ENV=development
LOG_LEVEL=debug
APP_BASE_URL=http://localhost:5173
